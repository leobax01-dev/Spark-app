{
  "functions": {
    "api/claude.js": {
      "maxDuration": 60
    },
    "api/stitch.js": {
      "maxDuration": 60
    },
    "api/higgsfield.js": {
      "maxDuration": 60
    },
    "api/higgsfield-poll.js": {
      "maxDuration": 60
    },
    "api/cron-autopilot.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron-autopilot",
      "schedule": "0 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" }
  ]
}
